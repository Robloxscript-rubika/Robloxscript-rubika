    local function CleanupExpandedHead(E)
        pcall(function()
            if not E or not E.Parent then return end
            local H = E:FindFirstChild("Head")
            local FH = E:FindFirstChild("FakeHead")
            if FH then
                if H then H.Size = FH.Size; H.Transparency = FH.Transparency end
                FH:Destroy()
            end
        end)
    end

    local function ExpandHead(E, hs)
        pcall(function()
            if not E or not E.Parent then return end
            local H = E:FindFirstChild("Head")
            if not H then return end

            if State.CurrentExpandedEnemy and State.CurrentExpandedEnemy ~= E then
                CleanupExpandedHead(State.CurrentExpandedEnemy)
                State.CurrentExpandedEnemy = nil
            end

            if E:FindFirstChild("FakeHead") then
                H.Size = Vector3.new(hs, hs, hs)
                H.Transparency = 1
                H.CanCollide = false
                State.CurrentExpandedEnemy = E
                return
            end

            State.CurrentExpandedEnemy = E
            local FH = H:Clone()
            FH.Name = "FakeHead"
            FH.CanCollide = false
            FH.Anchored = false
            FH.Massless = true
            FH.Size = H.Size
            FH.Transparency = H.Transparency
            FH.Parent = E

            local W = Instance.new("WeldConstraint")
            W.Part0 = H; W.Part1 = FH; W.Parent = FH

            H.Size = Vector3.new(hs, hs, hs)
            H.Transparency = 1
            H.CanCollide = false

            for _, c in pairs(H:GetChildren()) do
                if c:IsA("SpecialMesh") or c:IsA("Decal") or c:IsA("FaceInstance") or c:IsA("Texture") then
                    c:Destroy()
                end
            end
            for _, c in pairs(H:GetChildren()) do
                if c:IsA("BillboardGui") then c.Adornee = FH end
            end
        end)
    end

    local function PrepareEnemy(E)
        pcall(function()
            if not E or not E.Parent then return end
            if not E:FindFirstChild("HumanoidRootPart") then return end
            ExpandHead(E, Settings.HeadSize)
            if Settings.FreezeEnemy and E:FindFirstChild("Humanoid") then
                E.Humanoid.WalkSpeed = 0
                E.Humanoid.JumpPower = 0
                if Settings.RemoveAnimator and E.Humanoid:FindFirstChild("Animator") then
                    E.Humanoid.Animator:Destroy()
                end
            end
            for _, p in pairs(E:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end)
    end

