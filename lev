    local function HasQuest()
        local g = Plr.PlayerGui:FindFirstChild("Main")
        return g and g:FindFirstChild("Quest") and g.Quest.Visible or false
    end

    local function Log(m) print("[LevelUp] " .. m) end

    local function IsEnemyValid(E)
        if not E or not E.Parent then return false end
        local hum = E:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        if not E:FindFirstChild("HumanoidRootPart") then return false end
        return true
    end

    local function IsBossAlive(n)
        local E = Workspace:FindFirstChild("Enemies")
        if E then
            for _, v in pairs(E:GetChildren()) do
                if string.find(v.Name, n) and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                    return true
                end
            end
        end
        return false
    end

    local function IsBossSpawned(n)
        local W = Workspace:FindFirstChild("_WorldOrigin")
        if W then
            local E = W:FindFirstChild("EnemySpawns")
            if E then
                for _, v in pairs(E:GetChildren()) do
                    if string.find(v.Name, n) then return true end
                end
            end
        end
        return IsBossAlive(n)
    end

    local function GetAggressiveSpawn(n)
        if SpawnCache[n] then return SpawnCache[n] end
        if Workspace:FindFirstChild("_WorldOrigin") and Workspace._WorldOrigin:FindFirstChild("EnemySpawns") then
            for _, v in pairs(Workspace._WorldOrigin.EnemySpawns:GetChildren()) do
                if string.find(v.Name, n) then SpawnCache[n] = v.CFrame; return v.CFrame end
            end
        end
        return nil
    end

    local function IsNearSubmerged()
        if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then return false end
        return (Plr.Character.HumanoidRootPart.Position - Vector3.new(10779,-2088,9262)).Magnitude < 2000
    end

    local function NeedsTravelToSubmerged()
        local ml = GetMyLevel()
        if ml < 2600 then return false end
        if State.TravelComplete then return false end
        if IsNearSubmerged() then State.TravelComplete = true; return false end
        return true
    end

