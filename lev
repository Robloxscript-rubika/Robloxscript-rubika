        end
        for _, t in pairs(Plr.Backpack:GetChildren()) do
            if t:IsA("Tool") and t.ToolTip == "Blox Fruit" then return t end
        end
        return nil
    end

    local function IsBuddhaFruit()
        local f = GetFruitTool()
        return f and string.find(string.lower(f.Name), "buddha") ~= nil
    end

    local function ShouldUseFinisher()
        if not State.CurrentTarget or not State.CurrentTarget.Instance then return false end
        local h = State.CurrentTarget.Instance:FindFirstChild("Humanoid")
        return h and h.Health <= Settings.SwitchHP
    end

    local function EquipWeapon()
        local wm = State.WeaponMode
        if wm == "Melee" then EquipMelee()
        elseif wm == "Sword" then EquipSword()
        elseif wm == "Gun" then EquipGun()
        elseif wm == "Fruit" then EquipFruit()
        elseif wm == "MeleeGun" then if ShouldUseFinisher() then EquipGun() else EquipMelee() end
        elseif wm == "MeleeAbility" then if ShouldUseFinisher() then EquipFruit() else EquipMelee() end
        end
    end

    local function UseAbilities()
        for _, k in ipairs({"Z","X","C","F"}) do
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[k], false, game)
            task.wait(0.05)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[k], false, game)
            task.wait(0.1)
        end
    end

    local function ShootAtTarget(tp)
        if not tp then return end
        local sp, on = Workspace.CurrentCamera:WorldToViewportPoint(tp.Position)
        if on then
            VirtualInputManager:SendMouseButtonEvent(sp.X, sp.Y, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(sp.X, sp.Y, 0, false, game, 1)
        end
    end

    -- ═══════════════════════════════════════
    -- دیالوگ
    -- ═══════════════════════════════════════
    local function ClickNevermind(DG)
        local VB = {}
        for _, v in pairs(DG:GetDescendants()) do
            if v:IsA("TextButton") and v.Visible then table.insert(VB, v) end
        end
        if #VB > 0 then
            local b = VB[#VB]
            local p = b.AbsolutePosition; local s = b.AbsoluteSize
            local I = GuiService:GetGuiInset()
            VirtualInputManager:SendMouseButtonEvent(p.X+s.X/2, p.Y+s.Y/2+I.Y, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(p.X+s.X/2, p.Y+s.Y/2+I.Y, 0, false, game, 1)
            return true
        end
        return false
    end

    local function HandleDialogue()
        pcall(function()
            local M = Plr.PlayerGui:FindFirstChild("Main"); if not M then return end
            local D = M:FindFirstChild("Dialogue")
            if D and D.Visible then
                State.IsSafeToClick = false
                task.wait(2); if D.Visible then ClickNevermind(D) end
                task.wait(2); if D.Visible then ClickNevermind(D) end
                task.wait(1)
            else
                if State.CurrentTarget and State.CurrentTarget.Mode == "Travel" then
                    State.IsSafeToClick = false
                else
                    State.IsSafeToClick = true
                end
            end
        end)
    end

    -- ═══════════════════════════════════════
    -- GetSmartQuest با قفل کوئست
    -- ═══════════════════════════════════════
    local function GetSmartQuest()
        -- اگه کوئست قفل شده، همون رو برگردون
        if State.QuestLocked and State.LockedQuestData then
            return State.LockedQuestData
        end

        local ml = GetMyLevel()
        local BD, BI, PBD = nil, 0, nil

        for i, d in ipairs(LevelUpDatabase) do
            if ml >= d.Lvl then BD = d; BI = i end
        end

        if not BD and #LevelUpDatabase > 0 then BD = LevelUpDatabase[1]; BI = 1 end
        if not BD then return nil end

        if BD.IsBoss then
            if not State.BossInLevelUp then
                for i = BI - 1, 1, -1 do
                    if not LevelUpDatabase[i].IsBoss then return LevelUpDatabase[i] end
                end
                return BD
            end
            for i = BI - 1, 1, -1 do
                if not LevelUpDatabase[i].IsBoss then PBD = LevelUpDatabase[i]; break end
            end
            local ba, bs = IsBossAlive(BD.Mob), IsBossSpawned(BD.Mob)
            if ml < BD.Lvl and PBD then return PBD end
            if State.BossQuestTaken and not ba and not bs then
                State.BossQuestTaken = false; State.BossKilledByOther = true
                if PBD then return PBD end
            end
            if bs or ba then
                if HasQuest() and not State.BossQuestTaken then
                    if State.CurrentQuestData and not State.CurrentQuestData.IsBoss then
                        State.WaitingForBoss = true; return State.CurrentQuestData
                    end
                end
                if not HasQuest() and ml >= BD.Lvl then
                    State.WaitingForBoss = false; State.BossQuestTaken = true
                    State.LastNormalQuestData = PBD; return BD
                end
                if State.BossQuestTaken then return BD end
            else
                State.BossQuestTaken = false; State.WaitingForBoss = false
                if PBD then return PBD end
            end
        end
        State.BossQuestTaken = false; State.WaitingForBoss = false
        return BD
    end

    -- ═══════════════════════════════════════
    -- Tick: منطق اصلی لول آپ (هر 0.5 ثانیه)
    -- ═══════════════════════════════════════
    local function Tick(Root, now)
        if not State.Enabled then return end

        -- سابمرج دریای سوم
        if Sea == 3 and NeedsTravelToSubmerged() and not State.TravelRequestSent then
            local SN = CFrame.new(-16271, 25, 1372)
            State.CurrentTarget = {Mode="Travel", CFrame=SN}
            State.IsSafeToClick = false
            if (Root.Position - SN.Position).Magnitude < 10 then
                task.wait(1)
                pcall(function() Net:FindFirstChild("RF/SubmarineWorkerSpeak"):InvokeServer("TravelToSubmergedIsland") end)
                State.TravelRequestSent = true; task.wait(8)
                if IsNearSubmerged() then State.TravelComplete = true; State.CurrentTarget = nil; State.IsSafeToClick = true end
            end
            return
        end
        if State.TravelRequestSent and not State.TravelComplete then
            if IsNearSubmerged() then State.TravelComplete = true; State.CurrentTarget = nil; State.IsSafeToClick = true
            else return end
        end

        local QData = GetSmartQuest()
        if not QData then return end
        State.CurrentQuestData = QData

        if HasQuest() then
            State.IsSafeToClick = true

            -- قفل کوئست
            if not State.QuestLocked then
                State.QuestLocked = true
                State.LockedQuestData = QData
                Log("کوئست قفل شد: " .. QData.Mob)
            end

            if State.CurrentTarget and State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                if IsEnemyValid(State.CurrentTarget.Instance) then
                    PrepareEnemy(State.CurrentTarget.Instance); return
                else
                    CleanupExpandedHead(State.CurrentTarget.Instance)
                    if State.CurrentExpandedEnemy == State.CurrentTarget.Instance then State.CurrentExpandedEnemy = nil end
                    State.CurrentTarget = nil
                end
            end

            local fm, md = nil, math.huge
            local targetMob = State.LockedQuestData and State.LockedQuestData.Mob or QData.Mob
            if Workspace:FindFirstChild("Enemies") then
                for _, v in pairs(Workspace.Enemies:GetChildren()) do
                    pcall(function()
                        if string.find(v.Name, targetMob) and IsEnemyValid(v) then
                            local d = (Root.Position - v.HumanoidRootPart.Position).Magnitude
                            if d < md then md = d; fm = v end
                        end
                    end)
                end
            end

            if fm then
                PrepareEnemy(fm)
                State.CurrentTarget = {Mode="Mob", Instance=fm}
                State.LastKnownSpawn = fm.HumanoidRootPart.CFrame
            else
                if QData.IsBoss and State.BossQuestTaken and not IsBossSpawned(QData.Mob) then
                    State.BossQuestTaken = false; State.BossKilledByOther = true
                    if State.LastNormalQuestData then State.CurrentQuestData = State.LastNormalQuestData end
                    return
                end
                if State.CurrentExpandedEnemy then CleanupExpandedHead(State.CurrentExpandedEnemy); State.CurrentExpandedEnemy = nil end
                local sp = GetAggressiveSpawn(targetMob)
                if sp then State.CurrentTarget = {Mode="Wait", CFrame=sp*CFrame.new(0,Settings.WaitHeight,0)}
                elseif State.LastKnownSpawn then State.CurrentTarget = {Mode="Wait", CFrame=State.LastKnownSpawn*CFrame.new(0,Settings.WaitHeight,0)}
                else State.CurrentTarget = {Mode="Wait", CFrame=QData.Pos*CFrame.new(0,50,0)} end
            end
        else
            -- کوئست تموم شد
            if State.QuestLocked then
                State.QuestLocked = false; State.LockedQuestData = nil
                Log("کوئست تموم شد، قفل باز شد")
            end

            if State.CurrentExpandedEnemy then CleanupExpandedHead(State.CurrentExpandedEnemy); State.CurrentExpandedEnemy = nil end
            State.LastKnownSpawn = nil; State.IsSafeToClick = false

            local freshQData = GetSmartQuest()
            if not freshQData then return end

            State.CurrentTarget = {Mode="NPC", CFrame=freshQData.Pos}
            if (Root.Position - freshQData.Pos.Position).Magnitude < 12 then
                task.wait(0.5)
                for a = 1, 3 do
                    pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", freshQData.QName, freshQData.QId) end)
                    task.wait(0.6); HandleDialogue(); task.wait(0.5)
                    if HasQuest() then
                        State.IsSafeToClick = true; State.CurrentTarget = nil
                        if freshQData.IsBoss then State.BossQuestTaken = true else State.LastNormalQuestData = freshQData end
                        State.QuestLocked = true; State.LockedQuestData = freshQData
                        Log("کوئست جدید قفل شد: " .. freshQData.Mob)
                        break
                    end
                    task.wait(0.3)
                end
            end
        end
    end

    -- ═══════════════════════════════════════
    -- لوپ حمله
    -- ═══════════════════════════════════════
    local function GetRandomDelay() return Settings.MinClickDelay + (math.random() * (Settings.MaxClickDelay - Settings.MinClickDelay)) end
    local function GetRandomAttackValue() return math.floor((0.5 + math.random() * 0.5) * 10000) / 10000 end

    task.spawn(function()
        while true do
            local Clicked = false
            pcall(function()
                if not State.Enabled or not State.IsSafeToClick then return end
                if not State.CurrentTarget or State.CurrentTarget.Mode ~= "Mob" or not State.CurrentTarget.Instance then return end

                local E = State.CurrentTarget.Instance
                if E ~= State.LastTargetEnemy then State.LastTargetEnemy = E; State.LastTargetTime = tick() end
                if tick() - State.LastTargetTime < Settings.AttackWaitTime then return end

                if not IsEnemyValid(E) then
                    CleanupExpandedHead(E)
                    if State.CurrentExpandedEnemy == E then State.CurrentExpandedEnemy = nil end
                    State.CurrentTarget = nil; State.LastTargetEnemy = nil; return
                end

                if not Plr.Character or not Plr.Character:FindFirstChild("Humanoid") then return end

                pcall(function()
                    if E:FindFirstChild("Head") then
                        Workspace.CurrentCamera.CFrame = CFrame.lookAt(Workspace.CurrentCamera.CFrame.Position, E.Head.Position)
                    end
                end)

                EquipWeapon()
                local Tool = Plr.Character:FindFirstChildOfClass("Tool")
                if Tool then
                    Clicked = true
                    local isGun = (State.WeaponMode == "Gun") or
                        (State.WeaponMode == "MeleeGun" and ShouldUseFinisher() and (Tool.ToolTip == "Gun" or Tool.ToolTip == "Guns"))

                    if isGun then
                        local tp = E:FindFirstChild("Head") or E:FindFirstChild("HumanoidRootPart")
                        if tp then ShootAtTarget(tp) end
                    else
                        local CX, CY = Workspace.CurrentCamera.ViewportSize.X/2, Workspace.CurrentCamera.ViewportSize.Y/2
                        VirtualInputManager:SendMouseButtonEvent(CX, CY, 0, true, game, 1)
                        task.wait(Settings.HoldTime)
                        VirtualInputManager:SendMouseButtonEvent(CX, CY, 0, false, game, 1)
                        if State.AttackMethod == "Click" then
                            RegisterAttack:FireServer(GetRandomAttackValue())
                        elseif State.AttackMethod == "RemoteHit" then
                            local R = E:FindFirstChild("HumanoidRootPart"); if R then RegisterHit:FireServer(R) end
                        end
                    end

                    if State.WeaponMode == "MeleeAbility" and ShouldUseFinisher() and Tool.ToolTip == "Blox Fruit" then
                        UseAbilities()
                    end
                end
            end)
            task.wait(Clicked and GetRandomDelay() or 0.15)
        end
    end)

    -- ═══════════════════════════════════════
    -- لوپ حرکت
    -- ═══════════════════════════════════════
    task.spawn(function()
        while true do
            pcall(function()
                if not State.Enabled then return end
                if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then return end
                local Root = Plr.Character.HumanoidRootPart
                local Dest = nil

                if State.CurrentTarget then
                    if State.CurrentTarget.Mode == "NPC" or State.CurrentTarget.Mode == "Wait" or State.CurrentTarget.Mode == "Travel" then
                        Dest = State.CurrentTarget.CFrame
                    elseif State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                        if not IsEnemyValid(State.CurrentTarget.Instance) then
                            CleanupExpandedHead(State.CurrentTarget.Instance)
                            State.CurrentTarget = nil; return
                        end
                        pcall(function()
                            if State.CurrentTarget.Instance:FindFirstChild("HumanoidRootPart") then
                                local EP = State.CurrentTarget.Instance.HumanoidRootPart.Position
                                local d = (Root.Position - EP); d = Vector3.new(d.X, 0, d.Z)
                                if d.Magnitude < 0.1 then d = Vector3.new(1,0,0) end; d = d.Unit
                                local ad, ah = Settings.AttackDistance, Settings.AttackHeight
                                if (State.WeaponMode == "Fruit" or State.WeaponMode == "MeleeAbility") and IsBuddhaFruit() then
                                    ad = Settings.BuddhaDistance
                                end
                                local T = Plr.Character:FindFirstChildOfClass("Tool")
                                if T and (T.ToolTip == "Gun" or T.ToolTip == "Guns") then
                                    ad = Settings.GunAttackDistance; ah = Settings.GunAttackHeight
                                end
                                Dest = CFrame.lookAt(EP + d * ad + Vector3.new(0, ah, 0), EP)
                            end
                        end)
                    end
                end

                if Dest then
                    if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
                    local dist = (Root.Position - Dest.Position).Magnitude
                    if dist < 10 then Root.CFrame = Dest
                    else
                        State.ActiveTween = TweenService:Create(Root, TweenInfo.new(math.max(dist/Settings.FlightSpeed, 0.05), Enum.EasingStyle.Linear), {CFrame=Dest})
                        State.ActiveTween:Play()
                    end
                end
            end)
            task.wait(0.12)
        end
    end)

    -- ═══════════════════════════════════════
    -- لوپ دوربین
    -- ═══════════════════════════════════════
    task.spawn(function()
        while task.wait(0.08) do
            pcall(function()
                if not State.Enabled then return end
                if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then return end
                if State.CurrentTarget and State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                    if State.CurrentTarget.Instance:FindFirstChild("HumanoidRootPart") then
                        local myPos = Plr.Character.HumanoidRootPart.Position + Vector3.new(0,2,0)
                        Workspace.CurrentCamera.CFrame = CFrame.lookAt(myPos, State.CurrentTarget.Instance.HumanoidRootPart.Position)
                    end
                end
            end)
        end
    end)

    -- ═══════════════════════════════════════
    -- Heartbeat
    -- ═══════════════════════════════════════
    RunService.Heartbeat:Connect(function()
        pcall(function()
            if not State.Enabled then return end

            -- پاکسازی FakeHead نامعتبر
            if State.CurrentExpandedEnemy then
                if not IsEnemyValid(State.CurrentExpandedEnemy) then
                    CleanupExpandedHead(State.CurrentExpandedEnemy)
                    State.CurrentExpandedEnemy = nil
                    if State.CurrentTarget and State.CurrentTarget.Instance == State.CurrentExpandedEnemy then
                        State.CurrentTarget = nil
                    end
                end
            end

            -- فریز دشمن
            if State.CurrentTarget and State.CurrentTarget.Mode == "Mob" and State.CurrentTarget.Instance then
                local E = State.CurrentTarget.Instance
                if E and E.Parent and E:FindFirstChild("Humanoid") then
                    E.Humanoid.WalkSpeed = 0; E.Humanoid.JumpPower = 0
                    for _, p in pairs(E:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                end
            end

            -- نوکلیپ
            if Plr.Character then
                for _, p in pairs(Plr.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
                if Plr.Character:FindFirstChild("HumanoidRootPart") then
                    Plr.Character.HumanoidRootPart.Velocity = Vector3.zero
                end
            end
        end)
    end)

    -- ═══════════════════════════════════════
    -- API عمومی ماژول
    -- ═══════════════════════════════════════
    local API = {}

    function API.Start()
        State.Enabled = true
        State.IsSafeToClick = true
        State.HasTransformed = false
        State.IsTransforming = false
        State.QuestLocked = false
        State.LockedQuestData = nil
        Log("شروع شد!")
    end

    function API.Stop()
        State.Enabled = false
        State.CurrentTarget = nil
        State.CurrentQuestData = nil
        State.BossQuestTaken = false
        State.WaitingForBoss = false
        State.QuestLocked = false
        State.LockedQuestData = nil
        State.IsSafeToClick = true
        if State.CurrentExpandedEnemy then
            CleanupExpandedHead(State.CurrentExpandedEnemy)
            State.CurrentExpandedEnemy = nil
        end
        if State.ActiveTween then State.ActiveTween:Cancel(); State.ActiveTween = nil end
        Log("متوقف شد!")
    end

    function API.SetWeaponMode(mode) State.WeaponMode = mode end
    function API.SetAttackMethod(method) State.AttackMethod = method end
    function API.SetBossInLevelUp(val) State.BossInLevelUp = val end
    function API.IsEnabled() return State.Enabled end

    function API.Tick(Root, now)
        Tick(Root, now)
    end

    function API.GetCurrentTarget() return State.CurrentTarget end
    function API.GetState() return State end
    function API.HandleDialogue() HandleDialogue() end
    function API.CleanupExpandedHead(E) CleanupExpandedHead(E) end

    return API
end

return LevelUpModule
