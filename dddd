local function HasTouchInterest(c) if not c or not c.Parent then return false end; if c:FindFirstChild("TouchInterest") then return true end; for _, ch in pairs(c:GetDescendants()) do if ch:IsA("TouchInterest") then return true end end; return false end
local function GetChestPosition(c) if not c or not c.Parent then return nil end; if c:IsA("BasePart") then return c.Position elseif c:IsA("Model") and c.PrimaryPart then return c.PrimaryPart.Position elseif c:IsA("Model") and c:FindFirstChild("Part") then return c.Part.Position end; return nil end
local function GetChestCFrame(c) if not c or not c.Parent then return nil end; if c:IsA("BasePart") then return c.CFrame elseif c:IsA("Model") and c.PrimaryPart then return c.PrimaryPart.CFrame elseif c:IsA("Model") and c:FindFirstChild("Part") then return c.Part.CFrame end; return nil end

local function GetNearestChest()
    local Root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart")
    if not Root then return nil end
    local nd, nc = math.huge, nil
    for _, v in pairs(Workspace:GetDescendants()) do
        if ValidChests[v.Name] and (v:IsA("BasePart") or v:IsA("Model")) and not ChestBuggedList[v] and HasTouchInterest(v) then
            local P = GetChestPosition(v)
            if P and P.Y > Settings.ChestMinHeight and P.Y < Settings.ChestMaxHeight then
                local D = (Root.Position - P).Magnitude
                if D < nd then nd = D; nc = v end
            end
        end
    end; return nc
end

local function AnyChestAvailable() for _, v in pairs(Workspace:GetDescendants()) do if ValidChests[v.Name] and (v:IsA("BasePart") or v:IsA("Model")) and not ChestBuggedList[v] and HasTouchInterest(v) then return true end end; return false end

local function CollectAllAvailableChests()
    while ChestFarmEnabled and not ChestStopSignal do
        local chest = GetNearestChest(); if not chest then return end
        ChestCurrentTarget = chest; local StartT = tick()
        if not ChestFailedAttempts[chest] then ChestFailedAttempts[chest] = 0 end
        ChestFailedAttempts[chest] = ChestFailedAttempts[chest] + 1
        if ChestFailedAttempts[chest] > Settings.ChestMaxAttempts then ChestBuggedList[chest] = true; ChestCurrentTarget = nil; task.wait(0.1); continue end

        while ChestFarmEnabled and not ChestStopSignal and chest and chest.Parent and HasTouchInterest(chest) do
            if ChestStopSignal or (DoughKingEnabled and HasGodsChalice()) then if ChestActiveTween then ChestActiveTween:Cancel(); ChestActiveTween=nil end; ChestCurrentTarget=nil; return end
            local Root = Plr.Character and Plr.Character:FindFirstChild("HumanoidRootPart"); if not Root then break end
            local Dest = GetChestCFrame(chest); if not Dest then break end
            local Dist = (Root.Position - Dest.Position).Magnitude
            if Dist < 6 then
                if ChestActiveTween then ChestActiveTween:Cancel() end
