            local bossesStr = ""; for _, d in ipairs(BossDatabase) do if IsBossSpawned(d.Mob) then bossesStr = bossesStr .. d.Mob .. " ، " end end; if bossesStr == "" then bossesStr = "هیچ باسی اسپان نشده" else bossesStr = string.sub(bossesStr, 1, -4) end
            
            local checkTime = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckTime", "DLCBoxData")
            local canBuy = ReplicatedStorage.Remotes.CommF_:InvokeServer("Cousin", "CheckCanBuyType", "DLCBoxData")
            local timeReady = (checkTime == true or tostring(checkTime):lower():find("true") or checkTime == 0 or tostring(checkTime):lower():find("ready"))
            local moneyReady = (canBuy == 1 or canBuy == true or tostring(canBuy) == "1" or tostring(canBuy) == "true")
            
            local gachaStr = ""; if timeReady then gachaStr = "آماده رول!" else local cleanTime = tostring(checkTime):match("%d+:[%d:]+"); if cleanTime then gachaStr = "مانده: " .. cleanTime else gachaStr = "در حال محاسبه..." end end; if not moneyReady then gachaStr = gachaStr .. " | ❌ پولت کافی نیست" end
            
            local fruitsStr = ""; for _,v in pairs(Workspace:GetChildren()) do if (v:IsA("Tool") or v:IsA("Model")) and string.find(v.Name,"Fruit") and not string.find(v.Name,"Dealer") and not string.find(v.Name,"Gacha") and not string.find(v.Name,"Blox Fruit") then fruitsStr = fruitsStr .. getCleanName(v.Name) .. " ، " end end; if fruitsStr == "" then fruitsStr = "هیچ میوه‌ای روی زمین نیست" else fruitsStr = string.sub(fruitsStr, 1, -4) end
            
            StatusPanel:SetDesc("🔰 لول فعلی: " .. lvl .. "\n\n💵 موجودی پول: $" .. money .. "\n\n🎣 ماهی های صید شده: " .. fishCaught .. "\n\n⚙️ وضعیت پلیر: " .. actionStr .. "\n\n🎁 چست‌های جمع شده: " .. TotalChestsCollected .. "\n\n🎰 وضعیت گاچا: " .. gachaStr .. "\n\n🏪 فروت‌های موجود در دیلر: " .. CachedDealerFruits .. "\n\n💀 باس‌های موجود: " .. bossesStr .. "\n\n🍎 میوه‌های روی زمین: " .. fruitsStr)
        end)
    end
end)

